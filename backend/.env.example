/**
 * Configuración de variables de entorno para el backend de InventoryPro.
 * Este archivo sirve como plantilla y documentación de las variables requeridas.
 * 
 * IMPORTANTE: Copiar este archivo como .env y completar los valores reales.
 * NUNCA subir el archivo .env al repositorio.
 */

# ============================================
# CONFIGURACIÓN DEL SERVIDOR
# ============================================
# Puerto en el que se ejecutará la API
PORT=3000

# Entorno de ejecución (development, production, test)
NODE_ENV=development

# ============================================
# BASE DE DATOS - PostgreSQL
# ============================================
# Prisma usa DOS conexiones (ver prisma/schema.prisma):
#
# DATABASE_URL  = conexión de runtime. En LOCAL, tu Postgres normal.
# DIRECT_URL    = conexión directa para MIGRACIONES (Prisma Migrate no puede correr por pgBouncer).
#
# --- LOCAL (Docker/local, sin pooling): ambas apuntan al mismo Postgres ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/inventory_pro?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/inventory_pro?schema=public"
#
# --- PRODUCCIÓN con SUPABASE (Project Settings > Database > Connection string) ---
# DATABASE_URL = pestaña "Transaction"/Pooling (pgBouncer, puerto 6543). Agregar &pgbouncer=true
#   Ej: postgresql://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true
# DIRECT_URL   = pestaña "Direct connection" (puerto 5432).
#   Ej: postgresql://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres

# ============================================
# AUTENTICACIÓN - JWT
# ============================================
# Clave secreta para firmar los tokens JWT.
# ⚠️ OBLIGATORIO cambiarlo en producción: con NODE_ENV=production el backend NO arranca si
# JWT_SECRET falta o es este valor de ejemplo (fail-fast, ver ADR-0004). Generá uno fuerte, p. ej.
# `openssl rand -base64 48`.
JWT_SECRET="inventory-pro-super-secret-key-change-in-production"

# Tiempo de expiración del token (ejemplos: 1h, 24h, 7d)
JWT_EXPIRATION="24h"

# ============================================
# CORS
# ============================================
# Orígenes permitidos para el frontend/mobile, separados por comas (sin '*').
# En desarrollo, si se omite, el default es http://localhost:5173 (Vite).
# ⚠️ En producción (NODE_ENV=production) CORS_ORIGIN es OBLIGATORIO: el backend no arranca si falta.
# Ejemplo prod: CORS_ORIGIN="https://app.midominio.com,https://admin.midominio.com"
CORS_ORIGIN="http://localhost:5173"

# ============================================
# CORREO ELECTRÓNICO - SMTP (para alertas)
# ============================================
MAIL_HOST="smtp.example.com"
MAIL_PORT=587
MAIL_USER="noreply@example.com"
MAIL_PASSWORD="your-mail-password"
MAIL_FROM="InventoryPro <noreply@example.com>"

# ============================================
# CONFIGURACIÓN DE ALERTAS
# ============================================
# Email del administrador para recibir alertas de stock bajo
ADMIN_EMAIL="admin@example.com"
