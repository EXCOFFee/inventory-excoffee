# ============================================
# Variables de entorno del Frontend (Vite)
# ============================================
# Copiar como .env.local para desarrollo. En Vercel se cargan en Project Settings > Environment Variables.
# Solo las variables con prefijo VITE_ se exponen al frontend.

# URL base de la API (backend). DEBE terminar en /api.
#
# --- PRODUCCIÓN (Vercel): reemplazar con la URL real del backend en Render ---
VITE_API_URL=https://TU-BACKEND.onrender.com/api

# --- DESARROLLO LOCAL (backend en Docker/local): ---
# VITE_API_URL=http://localhost:3000/api
